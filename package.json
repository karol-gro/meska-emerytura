{
	"name": "meska-emerytura",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@11.7.0",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "pnpm test:unit -- --run",
		"lint": "prettier --check . && pnpm lint:dashes",
		"lint:dashes": "node scripts/check-dashes.js",
		"format": "prettier --write . && node scripts/check-dashes.js --fix"
	},
	"devDependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.25.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.70.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tabler/icons-svelte": "^3.45.0",
		"@tailwindcss/vite": "^4.3.0",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"shadcn-svelte": "^1.4.2",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"wrangler": "^4.112.0"
	},
	"dependencies": {
		"@fontsource-variable/montserrat": "^5.2.8"
	}
}
